# Splunk management API (port 8089, NOT the Web UI on 8000)
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_SCHEME=https
SPLUNK_TOKEN=PASTE_YOUR_SPLUNK_TOKEN_HERE
VERIFY_SSL=false

# Standalone MCP bridge (livehybrid/splunk-mcp) — must NOT use port 8000 (Splunk Web UI)
FASTMCP_PORT=8765
FASTMCP_LOG_LEVEL=INFO

# Official Splunk MCP app endpoint (Splunkbase app 7931) — use after app install
SPLUNK_OFFICIAL_MCP_URL=https://localhost:8089/services/mcp

# Bridge MCP SSE base URL
SPLUNK_MCP_BRIDGE_URL=http://localhost:8765

# SentinelOps
SPLUNK_USE_MOCK=false
SAMPLE_LOG_PATH=sample_incidents.log
ANTHROPIC_API_KEY=
PROPOSER_MODEL=claude-3-5-sonnet-20241022
CHROMA_PERSIST_DIR=.chroma
